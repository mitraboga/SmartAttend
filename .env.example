# Application
SMARTATTEND_APP_TITLE=SmartAttend

# Admin login
SMARTATTEND_ADMIN_USER=admin
SMARTATTEND_ADMIN_PASSWORD=change-this-password

# Storage locations
SMARTATTEND_DATA_DIR=data
SMARTATTEND_MODELS_DIR=models
SMARTATTEND_ARTIFACTS_DIR=artifacts
SMARTATTEND_DATABASE_PATH=data/smartattend.db

# Runtime thresholds
SMARTATTEND_FACE_DETECTOR_BACKEND=auto
SMARTATTEND_RECOGNITION_THRESHOLD=0.75
SMARTATTEND_LIVENESS_THRESHOLD=0.50
SMARTATTEND_FACE_MATCHER_THRESHOLD=0.90
